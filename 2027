.hero-bg {
  position: relative;
  background-image:
    radial-gradient(circle at top center, rgba(255,255,255,0.15), transparent 55%),
    linear-gradient(to bottom, rgba(0,0,0,0.55), rgba(0,0,0,0.9)),
    url("https://images.unsplash.com/photo-1508098682722-e99c43a406b2");
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  color: #fff;
  overflow: hidden;
}
